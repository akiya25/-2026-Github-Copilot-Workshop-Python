# Copilot Web Relay - 環境変数設定例

# サーバー設定
PORT=3001
NODE_ENV=development

# Copilot SDK モデル（利用可能なモデル例）
# - gpt-5.4 (default)
# - gpt-5.4-mini
# - gpt-5-mini
# - claude-sonnet-4.6
# - claude-opus-4.7
COPILOT_MODEL=gpt-5.4

# CORS 設定（カンマ区切りで複数オリジンを指定）
CORS_ORIGINS=http://localhost:5173

# WebSocket 設定
WS_RECONNECT_INTERVAL=3000
WS_HEARTBEAT_INTERVAL=30000

# セッションタイムアウト（ミリ秒）
SESSION_IDLE_TIMEOUT=600000
SESSION_ABSOLUTE_TIMEOUT=1800000

# メッセージサイズ制限
MAX_MESSAGE_SIZE=4096
MAX_CONTENT_LENGTH=2000

# ログレベル（debug, info, warn, error）
LOG_LEVEL=info
